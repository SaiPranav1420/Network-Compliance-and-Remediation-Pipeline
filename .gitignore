# Virtual Environment
venv/
.venv/
ENV/

# Python Cache
__pycache__/
*.py[cod]
*$py.class

# Dynamically generated backups and reports
configs/*.txt
reports/*.txt

# Allow directories to be tracked but not their dynamic text content
!configs/.gitkeep
!reports/.gitkeep

# Ansible retry files and secrets
*.retry
.ansible/
